# Auto-normalize line endings
* text=auto

# Force LF for source code
*.kt text eol=lf
*.java text eol=lf
*.xml text eol=lf
*.kts text eol=lf
*.properties text eol=lf
*.pro text eol=lf
*.md text eol=lf
*.toml text eol=lf

# Binary files
*.keystore binary
*.jks binary
*.png binary
*.jpg binary
*.webp binary
